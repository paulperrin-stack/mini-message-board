<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
</head>
<body>
    <h1>Mini Message Board</h1>

    <a href="/new">Add New Message</a>

    <ul>
        <% messages.forEach(message => { %>
            <li>
                <strong><%= message.user %></strong>:
                <%= message.text %>
                <br>
                <small><%= message.added %></small>
            </li>
        <% }) %>
    </ul>
</body>
</html>